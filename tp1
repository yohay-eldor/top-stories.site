        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('article-search');
            
            // Function to filter articles based on search term
            const filterArticles = (searchTerm) => {
                const term = searchTerm.toLowerCase().trim();
                
                // Select all articles marked as searchable
                const allArticles = document.querySelectorAll('.searchable-article');
                
                // Select all date markers (to hide them if no articles are visible in their section)
                const dateMarkers = document.querySelectorAll('.date-marker');

                // Keep track of which news sections should remain visible
                const visibleSections = new Set();
                
                allArticles.forEach(card => {
                    const articleTitle = card.querySelector('h2').textContent.toLowerCase();
                    const articleContent = card.querySelector('.article-content').textContent.toLowerCase();

                    // Find the parent section ID for checking visibility later
                    const sectionId = card.closest('.news-section').id;

                    if (articleTitle.includes(term) || articleContent.includes(term)) {
                        card.style.display = 'block'; // Show article
                        visibleSections.add(sectionId);
                    } else {
                        card.style.display = 'none'; // Hide article
                    }

                // Control visibility of entire news sections based on visible articles within them
                document.querySelectorAll('.news-section').forEach(section => {
                    if (visibleSections.has(section.id) || term === '') {
                        section.style.display = 'block';
                    } else {
                        section.style.display = 'none';
                    }
                });


                // If the search term is empty, ensure all cards and sections are visible
                if (term === '') {
                    allArticles.forEach(card => card.style.display = 'block');
                    document.querySelectorAll('.news-section').forEach(section => section.style.display = 'block');
                }
            };

            // Event listener for the search input
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    filterArticles(e.target.value);
                });
            }
            
            // Initial call to ensure correct display on load
            filterArticles('');
        });
    </script>
</body>
